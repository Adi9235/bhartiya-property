# Any key left blank falls back to the default in src/lib/site-config.ts.
# Blank values are treated as unset, so an empty key never reaches the UI.

# Public site URL (no trailing slash). Used for canonical URLs, sitemap and Open Graph.
NEXT_PUBLIC_SITE_URL=

# Business contact details surfaced in the UI
NEXT_PUBLIC_PHONE=
NEXT_PUBLIC_WHATSAPP=
NEXT_PUBLIC_EMAIL=

# Google Maps embed (optional, OFF by default).
# The map section is hidden entirely unless this is set. To enable it, paste the "src"
# value from Google Maps > Share > Embed a map. Best done after you have created a
# Google Business Profile, so the pin lands on your actual office.
NEXT_PUBLIC_MAPS_EMBED_URL=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Server-side lead delivery (optional). Leave blank to log leads to the server console.
LEAD_WEBHOOK_URL=
LEAD_NOTIFY_EMAIL=
# Google Search Console verification token (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
